NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=https://brandmind-ai-eight.vercel.app

# Anthropic Claude (for AI Skills)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini API key for image generation
GEMINI_API_KEY=your-gemini-api-key

# Social Media OAuth — register apps at:
# Meta: https://developers.facebook.com/apps/
# TikTok: https://developers.tiktok.com/

# Instagram + Facebook share Meta App credentials
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Optional: separate Instagram app (otherwise reuses Facebook credentials)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# TikTok for Developers
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google Analytics 4 — register at https://console.cloud.google.com/
# Enable: Google Analytics Data API + Google Analytics Admin API
# OAuth consent screen: add scope analytics.readonly
GOOGLE_ANALYTICS_CLIENT_ID=
GOOGLE_ANALYTICS_CLIENT_SECRET=

# Shopify credentials are stored in the integrations table, not here
# Users add their Shopify stores via Settings > 平台连接
